{
  "name": "buidco-backend",
  "version": "0.1.0",
  "private": true,
  "description": "BUIDCO Project Monitoring Dashboard — Express + TypeScript API",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:seed-admin": "tsx src/db/seedAdmin.ts",
    "db:seed-projects": "tsx src/db/seedProjects.ts",
    "db:studio": "drizzle-kit studio",
    "db:backfill-divisions": "tsx src/scripts/backfillDivisions.ts",
    "gen:input-template": "tsx src/scripts/generateInputSheetTemplate.ts"
  },
  "dependencies": {
    "@upstash/ratelimit": "^2.0.3",
    "@upstash/redis": "^1.34.0",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.33.0",
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.12.0",
    "uploadthing": "^7.0.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.14.9",
    "@types/pg": "^8.11.6",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^7.16.0",
    "@typescript-eslint/parser": "^7.16.0",
    "drizzle-kit": "^0.24.0",
    "eslint": "^8.57.0",
    "exceljs": "^4.4.0",
    "supertest": "^7.0.0",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3",
    "vitest": "^2.0.2"
  }
}
