# =============================================================================
# BUIDCO backend — configuration template.
#
# HOW TO USE:
#   Copy this file to `.env.local` and fill in real values there.
#   NEVER commit `.env.local` — it is gitignored.
#   NEVER put real secrets in THIS file — anything committed is public.
#
# HOW TO GENERATE FRESH JWT SECRETS:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# =============================================================================

NODE_ENV=development
PORT=4000

# Postgres connection. For Neon: use the connection string from your
# project dashboard. `?sslmode=require` is required in production.
DATABASE_URL=postgres://user:password@host:5432/dbname

# JWT signing secrets — MUST be at least 32 characters each.
# Use DIFFERENT values for access vs refresh.
JWT_ACCESS_SECRET=replace-with-32-plus-char-random-base64
JWT_REFRESH_SECRET=replace-with-32-plus-char-random-base64
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=2592000

# Comma-separated list of origins that may call the API from a browser.
# In production this is your Vercel frontend origin, e.g.
#   https://buidco-dashboard.vercel.app
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Upstash Redis (REST) — login + upload rate limiting.
# Get these from your Upstash console -> your database -> REST API tab.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# UploadThing — only if you enable geo-photo file uploads.
UPLOADTHING_TOKEN=

# Optional. Set only if API and SPA share the same parent domain and you
# want the refresh cookie shared across subdomains. For Render + Vercel
# on different domains, leave BLANK.
COOKIE_DOMAIN=
