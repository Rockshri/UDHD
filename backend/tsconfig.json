{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "lib": ["ES2022"],
    "strict": true,
    "noImplicitAny": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    // exactOptionalPropertyTypes disabled: Drizzle's insert/update types
    // expect properties to be *absent* rather than `undefined`, but Zod
    // `.optional()` inference produces `T | undefined`. Every insert with a
    // Zod-derived payload would need a manual "strip undefined" pass. The
    // runtime behavior is correct (Drizzle drops undefined columns from the
    // generated SQL) — this flag is off to accept the friction.
    "exactOptionalPropertyTypes": false,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": false,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": "src",
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
